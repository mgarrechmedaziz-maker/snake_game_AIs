        for j in range(1,len(genomes)):
            genome= BestGenome.copy()
            for i in range(111):
                if random.random() < 0.3:
                    genome[i] += random.uniform(-2.0,2.0)
            genomes[j]=genome
        #if tries % 10 ==1 : n+=10

GA()
        